# Database - Neon PostgreSQL
# Copy toan bo connection string vao day (VD: postgresql://user:pass@host/db?sslmode=require)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Server (Render tu dong dat PORT)
PORT=3000
NODE_ENV=production

# JWT - Tao chuoi ngau nhien dai 32+ ky tu
JWT_SECRET=your-super-long-random-secret-key-change-this
JWT_EXPIRES_IN=7d

# CORS - Domain Vercel cua ban (VD: https://your-app.vercel.app)
CORS_ORIGIN=https://your-frontend.vercel.app
